# # ALGORITHM=HS256
# # ACCESS_TOKEN_EXPIRE_MINUTES=1440

# # # Google Gemini API Key
# # GEMINI_API_KEY=your-gemini-api-key

# # # CORS Origins (comma-separated)
# # CORS_ORIGINS=http://localhost:5173,http://localhost:3000

